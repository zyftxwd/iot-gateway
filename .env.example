MYSQL_DATABASE=iiot_db
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=iiot
MYSQL_PASSWORD=iiot123456

BACKEND_PORT=8080
FRONTEND_PORT=5173

IIOT_COLLECTOR_NODE_ID=docker-dev
IIOT_COLLECTOR_DISPATCH_RATE_MS=1000
IIOT_COLLECTOR_POOL_SIZE=8
IIOT_COLLECTOR_QUEUE_CAPACITY=2000

IIOT_AUTH_TOKEN_SECRET=change-this-to-a-long-random-production-secret
IIOT_AUTH_TOKEN_TTL_MINUTES=480
IIOT_AUTH_MAX_LOGIN_FAILURES=5
IIOT_AUTH_LOCK_MINUTES=10

SPRING_FLYWAY_ENABLED=true
